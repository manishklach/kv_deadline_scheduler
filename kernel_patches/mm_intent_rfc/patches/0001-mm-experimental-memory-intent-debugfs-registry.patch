 include/linux/memory_intent.h |  58 +++++++++++
 mm/Kconfig                    |  14 +++
 mm/Makefile                   |   1 +
 mm/memory_intent.c            | 249 ++++++++++++++++++++++++++++++++++++++++++
 4 files changed, 322 insertions(+)
 create mode 100644 include/linux/memory_intent.h
