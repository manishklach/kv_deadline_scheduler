From 2c32d0c79e6e1cd4d96c2fe04738fd180348b73a Mon Sep 17 00:00:00 2001
From: Manish Klach <kv_deadline_scheduler>
Date: Wed, 17 Jun 2026 14:00:00 -0700
Subject: [PATCH 1/4] mm: add experimental memory intent debugfs registry

Add an RFC v0, debugfs-only memory-intent registry targeted initially at
Linux 6.8.y.

This patch is observability-only. It does not change reclaim behavior,
does not alter VM policy, and does not claim a stable ABI. The goal is to
let userspace register virtual-address ranges with generic intent flags so
research tooling can inspect what was tagged before any policy work is
attempted.

The interface is intentionally debugfs-only:

  /sys/kernel/debug/mm_intent/register
  /sys/kernel/debug/mm_intent/dump
  /sys/kernel/debug/mm_intent/clear

Input format for register is:

  <pid> <start_vaddr_hex> <length_hex> <intent_flags_hex> <deadline_ns> <priority>

Virtual-address ranges are used instead of PFNs because userspace naturally
knows virtual addresses, while PFNs are unstable under migration and often
hard to obtain.

Signed-off-by: Manish Klach <kv_deadline_scheduler>
---
 include/linux/memory_intent.h |  38 +++++++
 mm/Kconfig                    |  15 +++
 mm/Makefile                   |   1 +
 mm/memory_intent.c            | 209 ++++++++++++++++++++++++++++++++++++++++++
 4 files changed, 263 insertions(+)
 create mode 100644 include/linux/memory_intent.h
 create mode 100644 mm/memory_intent.c

diff --git a/include/linux/memory_intent.h b/include/linux/memory_intent.h
new file mode 100644
index 000000000000..04baf332d6db
--- /dev/null
+++ b/include/linux/memory_intent.h
@@ -0,0 +1,38 @@
+#ifndef _LINUX_MEMORY_INTENT_H
+#define _LINUX_MEMORY_INTENT_H
+
+#include <linux/list.h>
+#include <linux/types.h>
+
+#define MM_INTENT_LATENCY_CRITICAL 0x1
+#define MM_INTENT_RECLAIMABLE      0x2
+#define MM_INTENT_PREFETCHABLE     0x4
+#define MM_INTENT_RECOMPUTE_OK     0x8
+#define MM_INTENT_BACKGROUND       0x10
+
+struct memory_intent_entry {
+	struct list_head node;
+	pid_t pid;
+	unsigned long start;
+	unsigned long end;
+	u64 intent_flags;
+	u64 deadline_ns;
+	u32 priority;
+};
+
+#if defined(CONFIG_EXPERIMENTAL_MEMORY_INTENT) || defined(CONFIG_DEBUG_FS)
+int memory_intent_init_debugfs(void);
+void memory_intent_exit_debugfs(void);
+#else
+static inline int memory_intent_init_debugfs(void)
+{
+	return 0;
+}
+
+static inline void memory_intent_exit_debugfs(void)
+{
+}
+#endif
+
+#endif /* _LINUX_MEMORY_INTENT_H */
diff --git a/mm/Kconfig b/mm/Kconfig
index 18af73bbcc1e..68d35241a01c 100644
--- a/mm/Kconfig
+++ b/mm/Kconfig
@@ -1234,6 +1234,21 @@ config ANON_VMA_NAME
 	  Allow anonymous memory mappings to be named.  This is useful when
 	  debugging userspace allocators and memory pressure behavior.
 
+config EXPERIMENTAL_MEMORY_INTENT
+	bool "Experimental memory intent debugfs registry"
+	depends on DEBUG_FS
+	help
+	  Add a debugfs-only, observability-first memory-intent registry for
+	  research. This interface is intended for pinned-kernel experiments
+	  and does not change reclaim behavior.
+
+	  The interface accepts virtual-address ranges together with generic
+	  intent flags such as LATENCY_CRITICAL and RECLAIMABLE.
+
+	  This is RFC v0 infrastructure only. It is not a stable ABI and
+	  should not be treated as production-ready.
+
 endmenu
 
 menu "Memory Debugging"
diff --git a/mm/Makefile b/mm/Makefile
index b92eb5c64548..7c3561dfb19e 100644
--- a/mm/Makefile
+++ b/mm/Makefile
@@ -111,6 +111,7 @@ obj-$(CONFIG_PAGE_REPORTING) += page_reporting.o
