From 6894bf0bb11873e83fca0dd2c3278da1da56f3d1 Mon Sep 17 00:00:00 2001
From: Manish Klach <kv_deadline_scheduler>
Date: Wed, 17 Jun 2026 13:03:00 -0700
Subject: [PATCH 4/4] mm: memory_intent: add reclaim scaffolding default off

Add default-off reclaim scaffolding for future intent-aware VM experiments.

This patch is intentionally last in the series. It should not be enabled
until registry, observability, and DAMON reporting have been validated on
a pinned Linux version.

Changes from earlier version:
  - Add proper inline stubs for memory_intent_reclaim_enabled() in the
    CONFIG_EXPERIMENTAL_MEMORY_INTENT=n case
  - Remove the provisional vmscan lookup stub because it used the
    reclaiming task PID and a kernel linear address, neither of which
    identifies the original userspace registration correctly
  - Keep the series compile-targeted while documenting the real design
    blockers for a future reclaim experiment: owner attribution, reverse
    mapping from page to userspace VMA, and an explicit runtime enable path

Signed-off-by: Manish Klach <kv_deadline_scheduler>
---
 include/linux/memory_intent.h |  2 ++
 mm/Kconfig                    |  7 +++++++
 mm/memory_intent.c            | 26 ++++++++++++++++++++++++++
 3 files changed, 35 insertions(+)

diff --git a/include/linux/memory_intent.h b/include/linux/memory_intent.h
index b7c3d1f08..c761df4d85 100644
--- a/include/linux/memory_intent.h
+++ b/include/linux/memory_intent.h
@@ -48,6 +48,7 @@ int memory_intent_register(struct memory_intent_region *region);
 void memory_intent_unregister(pid_t pid, unsigned long start_vaddr);
 bool memory_intent_lookup_attrs(pid_t pid, unsigned long vaddr,
 				struct memory_intent_attrs *out);
+bool memory_intent_reclaim_enabled(void);
 int memory_intent_dump_seq(struct seq_file *m);
 int memory_intent_init_debugfs(void);
 void memory_intent_exit_debugfs(void);
@@ -61,6 +62,7 @@ static inline void memory_intent_unregister(pid_t pid, unsigned long start_vaddr
 static inline bool memory_intent_lookup_attrs(pid_t pid, unsigned long vaddr,
 					      struct memory_intent_attrs *out)
 {
 	return false;
 }
+static inline bool memory_intent_reclaim_enabled(void) { return false; }
 static inline int memory_intent_dump_seq(struct seq_file *m) { return 0; }
 static inline int memory_intent_init_debugfs(void) { return 0; }
 static inline void memory_intent_exit_debugfs(void) {}
 #endif
diff --git a/mm/Kconfig b/mm/Kconfig
index 15c00c842c..46d28a349a 100644
--- a/mm/Kconfig
+++ b/mm/Kconfig
@@ -1275,6 +1275,13 @@ config EXPERIMENTAL_MEMORY_INTENT_PROC
 	help
 	  Expose registered memory-intent regions through proc for research.
 
+config EXPERIMENTAL_MEMORY_INTENT_RECLAIM
+	bool "Experimental memory intent reclaim policy"
+	depends on EXPERIMENTAL_MEMORY_INTENT
+	help
+	  Experimental, default-off reclaim policy hook. Enable only after
+	  the observability path has been validated.
+
 source "mm/damon/Kconfig"
 
 endmenu
diff --git a/mm/memory_intent.c b/mm/memory_intent.c
index e4a6b2f8d..d7678fb0c 100644
--- a/mm/memory_intent.c
+++ b/mm/memory_intent.c
@@ -24,6 +24,7 @@
 #include <linux/seq_file.h>
 #include <linux/slab.h>
+#include <linux/static_key.h>
 #include <linux/uaccess.h>
 
 #define MM_INTENT_LINE_MAX 128
@@ -30,6 +31,13 @@
 static DEFINE_MUTEX(memory_intent_lock);
+#ifdef CONFIG_EXPERIMENTAL_MEMORY_INTENT_RECLAIM
+DEFINE_STATIC_KEY_FALSE(memory_intent_reclaim_key);
+#endif
 static struct dentry *memory_intent_dir;
 
 /*
@@ -99,6 +107,25 @@ int memory_intent_dump_seq(struct seq_file *m)
 	return 0;
 }
 
+bool memory_intent_reclaim_enabled(void)
+{
+#ifdef CONFIG_EXPERIMENTAL_MEMORY_INTENT_RECLAIM
+	return static_branch_unlikely(&memory_intent_reclaim_key);
+#else
+	return false;
+#endif
+}
+
+/*
+ * RFC note: this patch intentionally stops at enable-state scaffolding.
+ * A real reclaim experiment needs a trustworthy mapping from struct page
+ * back to the owning userspace VMA and registered PID before intent can
+ * influence reclaim decisions.
+ */
 /*
  * Debugfs interface
  */
