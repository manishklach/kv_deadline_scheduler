@@ -1508,6 +1509,7 @@ static unsigned int shrink_page_list(struct list_head *page_list,
 	LIST_HEAD(ret_pages);
 	LIST_HEAD(free_pages);
 	unsigned int nr_reclaimed = 0;
+	const struct memory_intent_region *intent;
 
 	cond_resched();
 
@@ -1578,6 +1580,24 @@ static unsigned int shrink_page_list(struct list_head *page_list,
 		if (!sc->may_unmap && page_mapped(page))
 			goto keep_locked;
 
+		if (memory_intent_reclaim_enabled()) {
+			/*
+			 * NOTE: page_address() returns the kernel linear-map
+			 * virtual address, not the userspace virtual address
+			 * stored in the intent registry.  A correct lookup
+			 * would need a page-table walk or VMA-based rmap.
+			 *
+			 * This is a research stub.  For experiments where
+			 * the direct-map and user-space addresses coincide
+			 * (e.g., simple test harnesses with MAP_FIXED), this
+			 * may produce useful results.
+			 */
+			intent = memory_intent_lookup(current->pid,
+				(unsigned long)page_address(page));
+			if (intent &&
+			    (intent->intent_flags & MM_INTENT_LATENCY_CRITICAL) &&
+			    !sc->may_swap)
+				goto keep_locked;
+		}
+
