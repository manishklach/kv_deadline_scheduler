diff --git a/mm/memory_intent_fs.c b/mm/memory_intent_fs.c
new file mode 100644
index 000000000..f7e6d2a4b
--- /dev/null
+++ b/mm/memory_intent_fs.c
@@ -0,0 +1,96 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Proc-oriented observability for the experimental memory-intent registry.
+ *
+ * Writes to /proc/memory_intent/register and /proc/memory_intent/unregister
+ * are forwarded to the core interval-tree API from memory_intent.c.
+ */
+
+#include <linux/init.h>
+#include <linux/kernel.h>
+#include <linux/memory_intent.h>
+#include <linux/overflow.h>
+#include <linux/proc_fs.h>
+#include <linux/seq_file.h>
+#include <linux/slab.h>
+#include <linux/uaccess.h>
+
+#define MM_INTENT_PROC_LINE_MAX 128
+
+static int memory_intent_status_show(struct seq_file *m, void *v)
+{
+	return memory_intent_dump_seq(m);
+}
+
+static int memory_intent_status_open(struct inode *inode, struct file *file)
+{
+	return single_open(file, memory_intent_status_show, NULL);
+}
+
+static ssize_t memory_intent_register_write(struct file *file,
+					    const char __user *buffer,
+					    size_t count, loff_t *ppos)
+{
+	char line[MM_INTENT_PROC_LINE_MAX];
+	struct memory_intent_region *region;
+	pid_t pid_nr;
+	unsigned int priority;
+	unsigned long start, length, flags, end;
+	u64 deadline_ns;
+	int parsed;
+
+	if (!count || count >= sizeof(line))
+		return -EINVAL;
+	if (copy_from_user(line, buffer, count))
+		return -EFAULT;
+	line[count] = '\0';
+
+	parsed = sscanf(line, "%d %lx %lx %lx %llu %u",
+			&pid_nr, &start, &length, &flags,
+			&deadline_ns, &priority);
+	if (parsed != 6)
+		return -EINVAL;
+	if (!length || check_add_overflow(start, length, &end))
+		return -EINVAL;
+
+	region = kzalloc(sizeof(*region), GFP_KERNEL);
+	if (!region)
+		return -ENOMEM;
+
+	region->node.start = start;
+	region->node.last = end - 1;
+	region->pid = pid_nr;
+	region->intent_flags = flags;
+	region->deadline_ns = deadline_ns;
+	region->priority = priority;
+
+	return memory_intent_register(region) ? -ENOMEM : count;
+}
+
+static ssize_t memory_intent_unregister_write(struct file *file,
+					      const char __user *buffer,
+					      size_t count, loff_t *ppos)
+{
+	char line[MM_INTENT_PROC_LINE_MAX];
+	pid_t pid_nr;
+	unsigned long start;
+
+	if (!count || count >= sizeof(line))
+		return -EINVAL;
+	if (copy_from_user(line, buffer, count))
+		return -EFAULT;
+	line[count] = '\0';
+
+	if (sscanf(line, "%d %lx", &pid_nr, &start) != 2)
+		return -EINVAL;
+
+	memory_intent_unregister(pid_nr, start);
+	return count;
+}
+
+static const struct proc_ops memory_intent_status_ops = {
+	.proc_open = memory_intent_status_open,
+	.proc_read = seq_read,
+	.proc_lseek = seq_lseek,
+	.proc_release = single_release,
+};
+
+static const struct proc_ops memory_intent_register_ops = {
+	.proc_write = memory_intent_register_write,
+};
+
+static const struct proc_ops memory_intent_unregister_ops = {
+	.proc_write = memory_intent_unregister_write,
+};
+
+static int __init memory_intent_proc_init(void)
+{
+	struct proc_dir_entry *root;
+
+	root = proc_mkdir("memory_intent", NULL);
+	if (!root)
+		return -ENOMEM;
+
+	if (!proc_create("status", 0444, root, &memory_intent_status_ops))
+		return -ENOMEM;
+	if (!proc_create("register", 0200, root, &memory_intent_register_ops))
+		return -ENOMEM;
+	if (!proc_create("unregister", 0200, root, &memory_intent_unregister_ops))
+		return -ENOMEM;
+
+	pr_info("experimental memory_intent proc observability initialized\n");
+	return 0;
+}
+
+fs_initcall(memory_intent_proc_init);
