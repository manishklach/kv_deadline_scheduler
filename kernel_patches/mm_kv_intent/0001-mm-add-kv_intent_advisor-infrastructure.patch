From 1f7b3bf0d8f6cc3bfb205ab684f5a5b38a12f4a1 Mon Sep 17 00:00:00 2001
From: Manish Klach <kv_deadline_scheduler>
Date: Wed, 17 Jun 2026 12:00:00 -0700
Subject: [PATCH 1/3] mm: add kv_intent_advisor infrastructure

Add a new optional mm subsystem, kv_intent_advisor, that allows
userspace serving engines (LLM inference, database buffer pools)
to register intent metadata for memory regions. The advisor uses
this metadata to guide reclaim decisions in the shrinker framework.

The core data structure is struct kv_region_intent, which carries:
- deadline_ns: absolute ktime deadline for this region's data
- priority: COLD/WARM/HOT/DECODE_CRITICAL classification
- pin_requested: prevents the region from being reclaim candidate
- recompute_cost_ns: cost of re-generating evicted data

Signed-off-by: Manish Klach <kv_deadline_scheduler>
---
 include/linux/kv_intent.h |  44 +++++++++++++
 mm/Kconfig                |  12 ++++
 mm/Makefile               |   1 +
 mm/kv_intent_advisor.c    | 131 +++++++++++++++++++++++++++++++++++++
 4 files changed, 188 insertions(+)
 create mode 100644 include/linux/kv_intent.h
 create mode 100644 mm/kv_intent_advisor.c

diff --git a/include/linux/kv_intent.h b/include/linux/kv_intent.h
new file mode 100644
index 000000000000..42c5038be101
--- /dev/null
+++ b/include/linux/kv_intent.h
@@ -0,0 +1,44 @@
+#ifndef _LINUX_KV_INTENT_H
+#define _LINUX_KV_INTENT_H
+
+#include <linux/types.h>
+#include <linux/list.h>
+#include <linux/rcu.h>
+#include <linux/ktime.h>
+
+#define KV_PRIORITY_COLD            0
+#define KV_PRIORITY_WARM            1
+#define KV_PRIORITY_HOT             2
+#define KV_PRIORITY_DECODE_CRITICAL 3
+
+struct kv_region_intent {
+	struct list_head  node;
+	unsigned long     start_pfn;
+	unsigned long     end_pfn;
+	ktime_t           deadline_ns;
+	ktime_t           registered_at;
+	u64               recompute_cost_ns;
+	int               priority;
+	bool              pin_requested;
+	bool              recompute_ok;
+	struct rcu_head   rcu;
+};
+
+#ifdef CONFIG_KV_INTENT_ADVISOR
+int  kv_intent_register(struct kv_region_intent *intent);
+void kv_intent_unregister(unsigned long start_pfn);
+int  kv_intent_get_priority(unsigned long pfn);
+bool kv_intent_is_pinned(unsigned long pfn);
+#else
+static inline int kv_intent_register(struct kv_region_intent *i)
+{
+	return 0;
+}
+static inline void kv_intent_unregister(unsigned long p)
+{
+}
+static inline int kv_intent_get_priority(unsigned long p)
+{
+	return KV_PRIORITY_COLD;
+}
+static inline bool kv_intent_is_pinned(unsigned long p)
+{
+	return false;
+}
+#endif
+#endif /* _LINUX_KV_INTENT_H */
diff --git a/mm/Kconfig b/mm/Kconfig
index 18af73bbcc1e..2b53af9eab20 100644
--- a/mm/Kconfig
+++ b/mm/Kconfig
@@ -1234,6 +1234,18 @@ config ANON_VMA_NAME
 	  Allow anonymous memory mappings to be named.  This is useful when
 	  debugging userspace allocators and memory pressure behavior.
 
+config KV_INTENT_ADVISOR
+	bool "KV intent advisor"
+	depends on MMU
+	help
+	  Adds a small MM-side advisory registry for userspace workloads that
+	  know reclaim value better than the kernel does.
+
+	  The initial target is long-context LLM inference, where decode-
+	  critical KV-cache pages may deserve stronger residency protection
+	  than cold prefill pages.  The interface is generic enough to be
+	  reused by other buffer-pool-style workloads.
+
 endmenu
 
 menu "Memory Debugging"
diff --git a/mm/Makefile b/mm/Makefile
index b92eb5c64548..8a2d0b6774d2 100644
--- a/mm/Makefile
+++ b/mm/Makefile
@@ -111,6 +111,7 @@ obj-$(CONFIG_PAGE_REPORTING) += page_reporting.o
 obj-$(CONFIG_MEMORY_FAILURE) += memory-failure.o
 obj-$(CONFIG_HWPOISON_INJECT) += hwpoison-inject.o
 obj-$(CONFIG_PER_VMA_LOCK_STATS) += per_vma_lock_stats.o
+obj-$(CONFIG_KV_INTENT_ADVISOR) += kv_intent_advisor.o
 
 KCOV_INSTRUMENT_mm-ksm.o := n
 KASAN_SANITIZE_khugepaged.o := n
diff --git a/mm/kv_intent_advisor.c b/mm/kv_intent_advisor.c
new file mode 100644
index 000000000000..fed1e1cf71ae
--- /dev/null
+++ b/mm/kv_intent_advisor.c
@@ -0,0 +1,131 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * kv_intent_advisor.c
+ *
+ * A PFN-keyed advisory registry for reclaim-sensitive userspace workloads.
+ */
+
+#include <linux/hashtable.h>
+#include <linux/init.h>
+#include <linux/kernel.h>
+#include <linux/kv_intent.h>
+#include <linux/module.h>
+#include <linux/rcupdate.h>
+#include <linux/rculist.h>
+#include <linux/slab.h>
+#include <linux/spinlock.h>
+
+#define KV_INTENT_HASH_BITS 8
+
+struct kv_region_entry {
+	struct hlist_node hnode;
+	struct kv_region_intent intent;
+};
+
+static DEFINE_HASHTABLE(kv_intent_table, KV_INTENT_HASH_BITS);
+static DEFINE_SPINLOCK(kv_intent_lock);
+
+static struct kv_region_entry *kv_intent_lookup(unsigned long pfn)
+{
+	struct kv_region_entry *entry;
+
+	hash_for_each_possible_rcu(kv_intent_table, entry, hnode, pfn) {
+		if (pfn >= entry->intent.start_pfn &&
+		    pfn < entry->intent.end_pfn)
+			return entry;
+	}
+
+	return NULL;
+}
+
+static void kv_intent_free_rcu(struct rcu_head *rcu)
+{
+	struct kv_region_entry *entry =
+		container_of(rcu, struct kv_region_entry, intent.rcu);
+
+	kfree(entry);
+}
+
+int kv_intent_register(struct kv_region_intent *intent)
+{
+	struct kv_region_entry *entry;
+	unsigned long flags;
+
+	if (!intent || intent->start_pfn >= intent->end_pfn)
+		return -EINVAL;
+
+	entry = kzalloc(sizeof(*entry), GFP_KERNEL);
+	if (!entry)
+		return -ENOMEM;
+
+	entry->intent = *intent;
+
+	spin_lock_irqsave(&kv_intent_lock, flags);
+	if (kv_intent_lookup(intent->start_pfn)) {
+		spin_unlock_irqrestore(&kv_intent_lock, flags);
+		kfree(entry);
+		return -EEXIST;
+	}
+	hash_add_rcu(kv_intent_table, &entry->hnode, intent->start_pfn);
+	spin_unlock_irqrestore(&kv_intent_lock, flags);
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(kv_intent_register);
+
+void kv_intent_unregister(unsigned long start_pfn)
+{
+	struct kv_region_entry *entry;
+	unsigned long flags;
+
+	spin_lock_irqsave(&kv_intent_lock, flags);
+	entry = kv_intent_lookup(start_pfn);
+	if (entry)
+		hash_del_rcu(&entry->hnode);
+	spin_unlock_irqrestore(&kv_intent_lock, flags);
+
+	if (entry)
+		call_rcu(&entry->intent.rcu, kv_intent_free_rcu);
+}
+EXPORT_SYMBOL_GPL(kv_intent_unregister);
+
+int kv_intent_get_priority(unsigned long pfn)
+{
+	struct kv_region_entry *entry;
+	int priority = KV_PRIORITY_COLD;
+
+	rcu_read_lock();
+	entry = kv_intent_lookup(pfn);
+	if (entry)
+		priority = entry->intent.priority;
+	rcu_read_unlock();
+
+	return priority;
+}
+EXPORT_SYMBOL_GPL(kv_intent_get_priority);
+
+bool kv_intent_is_pinned(unsigned long pfn)
+{
+	struct kv_region_entry *entry;
+	bool pinned = false;
+
+	rcu_read_lock();
+	entry = kv_intent_lookup(pfn);
+	if (entry)
+		pinned = entry->intent.pin_requested;
+	rcu_read_unlock();
+
+	return pinned;
+}
+EXPORT_SYMBOL_GPL(kv_intent_is_pinned);
+
+static int __init kv_intent_advisor_init(void)
+{
+	hash_init(kv_intent_table);
+	pr_info("kv_intent_advisor initialized\n");
+	return 0;
+}
+
+static void __exit kv_intent_advisor_exit(void)
+{
+	pr_info("kv_intent_advisor exited\n");
+}
+
+subsys_initcall(kv_intent_advisor_init);
+module_exit(kv_intent_advisor_exit);
-- 
